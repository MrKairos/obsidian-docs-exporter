{
  "name": "obsidian-docs-exporter",
  "version": "1.1.0",
  "description": "Obsidian plugin to export notes as styled, self-contained HTML — theme picker, syntax highlighting, TOC, callouts and a click-to-zoom image lightbox.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "html-export",
    "markdown",
    "typescript"
  ],
  "author": "MrKairos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrKairos/obsidian-docs-exporter.git"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.2",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2"
  }
}
